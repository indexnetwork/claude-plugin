########################################
# Required
########################################

# Postgres connection
DATABASE_URL=postgresql://username:password@localhost:5432/protocol_db

# OpenAI for LLM features (agents, intent generation)
OPENAI_API_KEY=your-openai-api-key

# Privy authentication (server)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Server
PORT=3001                 # default: 3001
NODE_ENV=development      # default: development

########################################
# Optional (defaults shown)
########################################

# Email (Resend). If not set, emails are skipped.
# RESEND_API_KEY=

# Redis cache. Use REDIS_URL or individual fields (default localhost:6379, db=0).
# REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Unstructured API (document parsing). If not set, some file types are disabled.
# UNSTRUCTURED_API_URL=

# Crawl4AI (web crawling for Index Links)
CRAWL4AI_BASE_URL=http://localhost:11235
# CRAWL4AI_TIMEOUT_MS=120000
# CRAWL4AI_MAX_DEPTH=1
# CRAWL4AI_MAX_PAGES=50
# CRAWL4AI_CONCURRENCY=4

# Composio (3rd‑party integrations like Gmail/Notion/Slack)
# If not set, integrations are disabled gracefully.
# COMPOSIO_API_KEY=

# Langfuse (tracing/observability)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Links sync behavior
# LINKS_SYNC_TRIGGER_BROKERS=false   # default: false (do not trigger brokers on sync)

# AWS S3 (currently unused; keep if you plan to enable S3 uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION=
# AWS_S3_BUCKET=

########################################
# Deprecated / Ignored
########################################

# JWT is not used; Privy provides auth.
# JWT_SECRET=
# JWT_EXPIRES_IN=

# Gmail received mail toggle is no longer supported; we index Sent only.
# GMAIL_INCLUDE_RECEIVED=
