# Protocol API base URL. Must include the /api path (server serves all routes under /api).
# Local dev: protocol runs on port 3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Privy (Web3 auth). Use same App ID as protocol PRIVY_APP_ID.
# https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Stream Chat (optional, for direct messaging)
# NEXT_PUBLIC_STREAM_API_KEY=
